# =====================================================
# CALCULADORA DE COSTOS - Configuracion de entorno
# =====================================================
# Copia este archivo como .env y ajusta los valores.
# En uso local solo necesitas MODO_DESARROLLO y SECRET_KEY.
# =====================================================


# ── Modo de desarrollo local ─────────────────────────────────
# True  = SQLite3, DEBUG activo, ALLOWED_HOSTS abierto (uso local)
# False = usa las variables de produccion de abajo
MODO_DESARROLLO=True


# ── Clave secreta de Django ───────────────────────────────────
# Cambiala en produccion. Generá una nueva con:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esta-clave-por-una-cadena-aleatoria-larga


# ── Las siguientes variables solo se usan si MODO_DESARROLLO=False ──

# Activar modo debug (no usar True en produccion)
DEBUG=False

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# Origenes de confianza para CSRF (necesario si usas HTTPS)
CSRF_TRUSTED_ORIGINS=https://tudominio.com

# Base de datos (por defecto SQLite3, descomenta para cambiar)
# DB_ENGINE=django.db.backends.sqlite3
# DB_PATH=/ruta/a/tu/base/db.sqlite3

# Archivos de media subidos por usuarios
# MEDIA_ROOT=/ruta/al/directorio/media
# MEDIA_URL=/media/
